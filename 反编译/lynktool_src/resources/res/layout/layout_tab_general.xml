<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/layoutContentGeneral" android:padding="16dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:baselineAligned="false">
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:background="@drawable/bg_toggle_group_item" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="96dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:paddingHorizontal="16dp" android:paddingVertical="12dp">
                <TextView android:textSize="19sp" android:textStyle="bold" android:textColor="?android:attr/textColorPrimary" android:ellipsize="end" android:gravity="start|center_vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:text="@string/floating_traffic_light_title" android:maxLines="1" android:layout_weight="1"/>
                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchFloatingTrafficLight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleX="1.3" android:scaleY="1.3" android:layout_marginEnd="6dp"/>
            </LinearLayout>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:background="@drawable/bg_toggle_group_item" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="96dp" android:layout_weight="1" android:layout_marginHorizontal="6dp" android:paddingHorizontal="16dp" android:paddingVertical="12dp">
                <TextView android:textSize="19sp" android:textStyle="bold" android:textColor="?android:attr/textColorPrimary" android:ellipsize="end" android:gravity="start|center_vertical" android:layout_width="0dp" android:layout_height="wrap_content" android:text="@string/floating_ball_title" android:maxLines="1" android:layout_weight="1"/>
                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchFloatingBall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleX="1.3" android:scaleY="1.3" android:layout_marginEnd="6dp"/>
            </LinearLayout>
            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout android:orientation="horizontal" android:id="@+id/layoutBootMapOptionsRow" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:baselineAligned="false">
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/layoutBootLaunchMapItem" android:background="@drawable/bg_toggle_group_item" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="96dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:paddingHorizontal="16dp" android:paddingVertical="12dp">
                <TextView android:textSize="19sp" android:textStyle="bold" android:textColor="?android:attr/textColorPrimary" android:ellipsize="end" android:gravity="start|center_vertical" android:id="@+id/textBootLaunchMap" android:layout_width="0dp" android:layout_height="wrap_content" android:text="自启启动吉利地图" android:maxLines="1" android:layout_weight="1"/>
                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchBootLaunchMap" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleX="1.3" android:scaleY="1.3" android:layout_marginEnd="6dp"/>
            </LinearLayout>
            <LinearLayout android:gravity="center_vertical" android:orientation="horizontal" android:id="@+id/layoutBootMapReturnHomeItem" android:background="@drawable/bg_toggle_group_item" android:layout_width="0dp" android:layout_height="wrap_content" android:minHeight="96dp" android:layout_weight="1" android:layout_marginStart="6dp" android:paddingHorizontal="16dp" android:paddingVertical="12dp">
                <TextView android:textSize="19sp" android:textStyle="bold" android:textColor="?android:attr/textColorPrimary" android:gravity="start|center_vertical" android:id="@+id/textBootMapReturnHomePrefix" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="启动吉利地图" android:maxLines="1"/>
                <Spinner android:id="@+id/spinnerBootLaunchMapReturnHomeDelay" android:layout_width="100dp" android:layout_height="wrap_content" android:spinnerMode="dropdown" android:layout_marginStart="6dp" android:layout_marginEnd="6dp"/>
                <TextView android:textSize="19sp" android:textStyle="bold" android:textColor="?android:attr/textColorPrimary" android:ellipsize="end" android:id="@+id/textBootMapReturnHomeSuffix" android:layout_width="0dp" android:layout_height="wrap_content" android:text="后返回桌面" android:maxLines="1" android:layout_weight="1" android:layout_marginEnd="8dp"/>
                <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchBootLaunchMapReturnHome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:scaleX="1.3" android:scaleY="1.3" android:layout_marginEnd="2dp"/>
            </LinearLayout>
            <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:layout_marginStart="6dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
